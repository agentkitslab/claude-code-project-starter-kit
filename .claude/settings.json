{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(pnpm test*)",
      "Bash(pytest*)",
      "Bash(uv run pytest*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(npm install*)",
      "Bash(pnpm install*)",
      "Bash(uv add*)",
      "Bash(pip install*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/id_rsa*)",
      "Read(**/*.pem)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl *|*sh*)",
      "Bash(wget *|*sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-reminder.sh"
          }
        ]
      }
    ]
  }
}
